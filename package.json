{
  "name": "wm-prototyp-live-music-coder",
  "private": true,
  "version": "1.0.3",
  "type": "module",
  "main": "out/main/main.cjs",
  "license": "AGPL-3.0-or-later",
  "author": "Arnold Wender <arnold.wender@gmail.com>",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "node scripts/inject-sw-version.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync:changelog": "npx tsx scripts/sync-changelog.ts",
    "electron:dev": "unset ELECTRON_RUN_AS_NODE && electron-vite dev",
    "electron:build": "unset ELECTRON_RUN_AS_NODE && electron-vite build && electron-builder",
    "electron:build:mac": "unset ELECTRON_RUN_AS_NODE && electron-vite build && electron-builder --mac",
    "electron:build:win": "unset ELECTRON_RUN_AS_NODE && electron-vite build && electron-builder --win",
    "electron:build:linux": "unset ELECTRON_RUN_AS_NODE && electron-vite build && electron-builder --linux"
  },
  "build": {
    "appId": "com.wendermedia.live-music-coder",
    "productName": "Live Music Coder",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "out/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.music",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": true
    },
    "win": {
      "target": [
        {
          "target": "nsis"
        },
        {
          "target": "portable"
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage"
        },
        {
          "target": "deb"
        }
      ],
      "category": "Audio"
    },
    "fileAssociations": [
      {
        "ext": "lmc",
        "name": "Live Music Coder Project",
        "description": "Live Music Coder project file",
        "role": "Editor"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "arnoldwender",
      "repo": "wm-prototyp-live-music-coder"
    }
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "@octokit/rest": "^22.0.1",
    "@replit/codemirror-vim": "^6.3.0",
    "@strudel/codemirror": "^1.3.0",
    "@strudel/core": "^1.2.6",
    "@strudel/draw": "^1.2.6",
    "@strudel/midi": "^1.3.0",
    "@strudel/mini": "^1.2.6",
    "@strudel/osc": "^1.3.2",
    "@strudel/serial": "^1.2.6",
    "@strudel/soundfonts": "^1.3.0",
    "@strudel/tonal": "^1.2.6",
    "@strudel/transpiler": "^1.2.6",
    "@strudel/web": "^1.3.0",
    "@strudel/webaudio": "^1.3.0",
    "@strudel/xen": "^1.2.6",
    "@tailwindcss/vite": "^4.2.2",
    "@xyflow/react": "^12.10.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "i18next": "^25.10.10",
    "idb": "^8.0.3",
    "lucide-react": "^1.8.0",
    "lz-string": "^1.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^16.6.6",
    "react-router-dom": "^7.14.0",
    "tailwindcss": "^4.2.2",
    "tone": "^15.1.22",
    "webmidi": "^3.1.16",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/lz-string": "^1.3.34",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5"
  }
}
